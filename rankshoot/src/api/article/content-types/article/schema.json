{
  "kind": "collectionType",
  "collectionName": "articles",
  "info": {
    "singularName": "article",
    "pluralName": "articles",
    "displayName": "Article",
    "description": "Blog posts generated from the SEO engine"
  },
  "options": {
    "draftAndPublish": true
  },
  "pluginOptions": {},
  "attributes": {
    "title": {
      "type": "string",
      "required": true
    },
    "slug": {
      "type": "uid",
      "targetField": "title",
      "required": true
    },
    "content": {
      "type": "richtext"
    },
    "excerpt": {
      "type": "text"
    },
    "meta_description": {
      "type": "text"
    },
    "target_keyword": {
      "type": "string"
    },
    "seo_score": {
      "type": "integer"
    },
    "word_count": {
      "type": "integer"
    },
    "cover_image_url": {
      "type": "string"
    },
    "source_blog_id": {
      "type": "string",
      "unique": true
    }
  }
}